# Supabase 프로젝트 설정
# Supabase 대시보드 → Settings → API 에서 복사
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Claude API (OCR 자동입력 기능)
# https://console.anthropic.com 에서 발급
VITE_ANTHROPIC_KEY=sk-ant-...

# 이카운트 Edge Function 프록시 URL
# supabase functions deploy ecount-proxy 후 대시보드에서 URL 복사
VITE_ECOUNT_PROXY_URL=https://[프로젝트ref].supabase.co/functions/v1/ecount-proxy
